{
  "name": "vlifewrapperfrontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && NODE_ENV=production next build",
    "build:local": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "clean": "rm -rf .next/cache",
    "clean:all": "rm -rf .next",
    "build:s3": "rm -rf .next && NODE_ENV=production next build",
    "deploy:s3": "npm run build:s3 && aws s3 sync out/ s3://$S3_BUCKET_NAME --delete",
    "deploy:staging": "npm run build:s3 && aws s3 sync out/ s3://$S3_STAGING_BUCKET --delete",
    "deploy:prod": "npm run build:s3 && aws s3 sync out/ s3://$S3_PROD_BUCKET --delete",
    "invalidate": "aws cloudfront create-invalidation --distribution-id $CLOUDFRONT_DISTRIBUTION_ID --paths '/*'",
    "deploy:full": "npm run deploy:prod && npm run invalidate",
    "deploy:ec2": "./deploy-ec2.sh",
    "deploy:ec2:ssl": "./deploy-ec2.sh",
    "build:ec2": "cp next.config.ec2.js next.config.js && npm run build && git checkout next.config.js",
    "config:ec2": "cp next.config.ec2.js next.config.js",
    "config:s3": "git checkout next.config.js"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@reduxjs/toolkit": "^2.9.2",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.5.1",
    "chartjs-chart-matrix": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "clsx": "^2.0.0",
    "countries-list": "^3.2.0",
    "lucide-react": "^0.290.0",
    "next": "^14.2.15",
    "postcss": "^8.4.48",
    "react": "^18.2.0",
    "react-apexcharts": "^1.4.3",
    "react-beautiful-dnd": "^13.1.1",
    "react-big-calendar": "^1.19.4",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-paginate": "^8.3.0",
    "react-redux": "^9.2.0",
    "react-slick": "^0.31.0",
    "redux-persist": "^6.0.0",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.15",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2"
  }
}
